      <species metaid="metaid_701" sboTerm="SBO:0000297" id="species_9933750" name="factor V (1047-1573) [extracellular region]" compartment="compartment_984" initialAmount="0" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false">
