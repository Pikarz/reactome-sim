      <reaction metaid="metaid_1092" id="reaction_418581" name="Activated P2Y purinoceptor 1 binds G-protein Gq" reversible="false" fast="false" compartment="compartment_876">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">P2Y1 is coupled to the Gq family of G protein alpha subunits, causing increases in intracellular calcium concentration through stimulation of PLC.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
