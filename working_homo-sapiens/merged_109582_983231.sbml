                <rdf:Bag>
                  <rdf:li rdf:resource="https://identifiers.org/uniprot:Q86W47"/>
                  <rdf:li rdf:resource="https://identifiers.org/uniprot:Q12791"/>
                  <rdf:li rdf:resource="https://identifiers.org/uniprot:Q9NPA1"/>
                  <rdf:li rdf:resource="https://identifiers.org/uniprot:Q16558"/>
                  <rdf:li rdf:resource="https://identifiers.org/uniprot:Q9Y691"/>
                </rdf:Bag>
              </bqbiol:hasPart>
            </rdf:Description>
          </rdf:RDF>
        </annotation>
      </species>
