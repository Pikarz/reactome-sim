      <reaction metaid="metaid_1051" id="reaction_432143" name="PECAM-1 binds PP2A" reversible="false" fast="false" compartment="compartment_70101">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">PECAM-1 co-immunoprecipitates with PP2A</p>
