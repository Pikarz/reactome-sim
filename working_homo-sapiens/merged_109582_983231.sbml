      <reaction metaid="metaid_1086" id="reaction_158781" name="crosslinked fibrin multimer + tissue plasminogen activator (one-chain) -&gt; crosslinked fibrin multimer:tissue plasminogen activator (one-chain)" reversible="false" fast="false" compartment="compartment_984">
