      <reaction metaid="metaid_1090" id="reaction_392187" name="Activated P2Y purinoceptor 12 binds G-protein Gi" reversible="false" fast="false" compartment="compartment_876">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">The activated receptor binds the inactive, GDP-bound form of the heterotrimeric G-protein Gi.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
