      <reaction metaid="metaid_891" id="reaction_396941" name="Thrombin-activated PARs binds G-protein G12/13" reversible="false" fast="false" compartment="compartment_876">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">Thrombin receptors activate G-proteins in the G12/13 family. Gq knockout mice exhibit defective platelet activation, but retain shape change responses to thrombin, mediated by G12/13.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
            <rdf:Description rdf:about="#metaid_891">
              <dc:creator>
                <rdf:Bag>
                  <rdf:li rdf:parseType="Resource">
                    <vCard:N rdf:parseType="Resource">
                      <vCard:Family>Jupe</vCard:Family>
                      <vCard:Given>Steve</vCard:Given>
                    </vCard:N>
                  </rdf:li>
                  <rdf:li rdf:parseType="Resource">
