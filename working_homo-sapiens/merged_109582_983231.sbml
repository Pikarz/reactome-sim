      <reaction metaid="metaid_916" id="reaction_202731" name="JAM3 dimerises" reversible="false" fast="false" compartment="compartment_876">
        <notes>
          <p xmlns="http://www.w3.org/1999/xhtml">JAM-C has been detected in epithelial-cell desmosomes. JAM-C homodimers are prominently located in endothelial-cell tight junctions.</p>
        </notes>
        <annotation>
          <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/">
