                  <rdf:li rdf:resource="https://identifiers.org/uniprot:P32121"/>
                </rdf:Bag>
              </bqbiol:hasPart>
              <bqbiol:isHomologTo>
                <rdf:Bag>
                  <rdf:li rdf:resource="https://identifiers.org/reactome:R-MMU-418167"/>
