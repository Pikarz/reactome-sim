    </apply>
  </math>
</kineticLaw>
      </reaction>
      <!-- Point 1: Input reaction: der(x_nucleus) = K_in - lambda_1*x_nucleus
           K_in is the constant source; the consumption by reaction_1855187 is already accounted for. -->
      <reaction id="reaction_input" reversible="false" fast="false">
        <listOfProducts>
          <speciesReference species="species_2023929" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/math/MathML">
            <ci> K_in </ci>
          </math>
        </kineticLaw>
      </reaction>
      <!-- Point 2: Output drain: der(x_ER) = lambda_1*x_nucleus - K_out
           K_out is a constant drain rate, symmetric to K_in in point 1.
           Production by reaction_1855187 is already accounted for. -->
      <reaction id="reaction_output_degradation" reversible="false" fast="false">
        <listOfReactants>
          <speciesReference species="species_2024018" stoichiometry="1" constant="true"/>
        </listOfReactants>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/math/MathML">
