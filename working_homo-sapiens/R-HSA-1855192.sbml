          </math>
        </kineticLaw>
      </reaction>
    </listOfReactions>

    <!-- Points 3 & 4: Rate rules for auxiliary ODE variables -->
    <listOfRules>

      <!-- Point 4: Running mean of nucleoplasm IP6
           der(y_2023929) = (species_2023929 - y_2023929) / (time + epsilon)
           => y_2023929(t) = (1/t) * integral_0^t species_2023929(tau) dtau -->
      <rateRule variable="y_2023929">
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <divide/>
            <apply>
              <minus/>
              <ci> species_2023929 </ci>
              <ci> y_2023929 </ci>
            </apply>
            <apply>
              <plus/>
              <csymbol encoding="text" definitionURL="http://www.sbml.org/sbml/symbols/time"> time </csymbol>
              <ci> epsilon </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <!-- Point 4: Running mean of ER lumen IP6 -->
      <rateRule variable="y_2024018">
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <divide/>
            <apply>
              <minus/>
              <ci> species_2024018 </ci>
              <ci> y_2024018 </ci>
            </apply>
            <apply>
              <plus/>
              <csymbol encoding="text" definitionURL="http://www.sbml.org/sbml/symbols/time"> time </csymbol>
              <ci> epsilon </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <!-- Point 4: Running 2nd moment of nucleoplasm IP6
           der(y2_2023929) = (species_2023929^2 - y2_2023929) / (time + epsilon)
           Variance  = y2_2023929 - y_2023929^2
           StdDev    = sqrt(y2_2023929 - y_2023929^2) -->
      <rateRule variable="y2_2023929">
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <divide/>
            <apply>
              <minus/>
              <apply>
                <power/>
                <ci> species_2023929 </ci>
                <cn type="integer"> 2 </cn>
              </apply>
              <ci> y2_2023929 </ci>
            </apply>
            <apply>
              <plus/>
              <csymbol encoding="text" definitionURL="http://www.sbml.org/sbml/symbols/time"> time </csymbol>
              <ci> epsilon </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <!-- Point 4: Running 2nd moment of ER lumen IP6 -->
      <rateRule variable="y2_2024018">
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <divide/>
            <apply>
              <minus/>
              <apply>
                <power/>
                <ci> species_2024018 </ci>
                <cn type="integer"> 2 </cn>
              </apply>
              <ci> y2_2024018 </ci>
            </apply>
            <apply>
              <plus/>
              <csymbol encoding="text" definitionURL="http://www.sbml.org/sbml/symbols/time"> time </csymbol>
              <ci> epsilon </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

    </listOfRules>

    <!-- Point 5: Concentration constraints – the time-averaged mean of each species
         must equal the target (mu_*). The optimizer adjusts K_in/K_out until satisfied. -->
    <listOfConstraints>
      <constraint>
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <leq/>
            <apply>
              <abs/>
              <apply>
                <minus/>
                <ci> y_2023929 </ci>
                <ci> mu_2023929 </ci>
              </apply>
            </apply>
            <cn> 1e-3 </cn>
          </apply>
        </math>
        <message>
          <p xmlns="http://www.w3.org/1999/xhtml">Mean of nucleoplasm IP6 (y_2023929) must equal target mu_2023929 = 0.5</p>
        </message>
      </constraint>
      <constraint>
        <math xmlns="http://www.w3.org/1998/math/MathML">
          <apply>
            <leq/>
