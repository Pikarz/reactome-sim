    <listOfParameters>
      <!-- Original parameters (Ku, Ur kept for reference but no longer used in reactions) -->
      <parameter id="Ku" value="10" constant="true"/>
      <parameter id="Ur" value="0.7" constant="true"/>
      <parameter id="lambda_1" value="3" constant="true"/>
      <!-- Point 1 & 2: Input/output rate parameters (optimized by OpenAI algorithm) -->
      <parameter id="K_in" value="1.5" constant="true"/>   <!-- der(x_nucleus) = K_in - lambda_1*x_nucleus -->
      <parameter id="K_out" value="3.0" constant="true"/>  <!-- der(x_ER)     = lambda_1*x_nucleus - K_out*x_ER -->
      <!-- Point 3: Threshold M for max-tracking constraint -->
      <parameter id="M" value="1.0" constant="true"/>
      <!-- Point 4: Small epsilon to avoid division by zero in running mean/moment -->
      <parameter id="epsilon" value="1e-6" constant="true"/>
      <!-- Point 5: Target time-averaged means per species (to be matched by optimizer) -->
      <parameter id="mu_2023929" value="0.5" constant="true"/>
