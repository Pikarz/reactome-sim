      <parameter id="y_2024018" value="0" constant="false"/>
      <!-- Point 4: Auxiliary vars for 2nd moment: der(y2_i) = (x_i^2 - y2_i)/(t + eps) -->
      <parameter id="y2_2023929" value="0" constant="false"/>
