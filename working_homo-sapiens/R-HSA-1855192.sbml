          <speciesReference constant="true" id="speciesreference_1855187_input_2023929" sboTerm="SBO:0000010" species="species_2023929" stoichiometry="1" />
        </listOfReactants>
        <listOfProducts>
          <speciesReference constant="true" id="speciesreference_1855187_output_2024018" sboTerm="SBO:0000011" species="species_2024018" stoichiometry="1" />
        </listOfProducts>
        <kineticLaw>
  <math xmlns="http://www.w3.org/1998/math/MathML">
    <apply>
      <times/>
      <ci> lambda_1 </ci>
      <apply>
        <power/>
        <ci> species_2023929 </ci>
        <cn type="integer"> 1 </cn>
